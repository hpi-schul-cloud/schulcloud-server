{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/app.js!",
		"apps/server/src/apps/*.ts!",
		"apps/server/src/migrations/**/*.ts!",
		"scripts/**/*.{js,ts}!"
	],
	"project": ["**/*.{js,ts}!"],
	"ignore": ["apps/server/src/core/**/*", "apps/server/src/infra/**/*", "src/**/*"]
}
