{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"entry": [
		"src/app.js!",
		"apps/server/src/apps/*.ts!",
		"apps/server/src/migrations/**/*.ts!",
		"scripts/**/*.{js,ts}!"
	],
	"project": ["**/*.{js,ts}!"],
	"ignore": [
		"apps/server/src/infra/authorization-client/authorization-api-client/**/*",
		"apps/server/src/infra/common-cartridge-clients/fs-generated/**/*",
		"apps/server/src/infra/common-cartridge-clients/generated/**/*",
		"apps/server/src/infra/etherpad-client/etherpad-api-client/**/*",
		"apps/server/src/infra/files-storage-client/generated/**/*",
		"apps/server/src/infra/h5p-editor-client/generated/**/*",
		"apps/server/src/infra/tldraw-client/generated/**/*",
		"apps/server/src/infra/tsp-client/generated/**/*",
		"apps/server/src/infra/vidis-client/generated/**/*"
	]
}
