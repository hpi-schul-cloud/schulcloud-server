apiVersion: v1
kind: ConfigMap
metadata:
  name: notification-server-configmap
  namespace: {{ NAMESPACE }}
  labels:
    app: notification-server
data:
  NEST_LOG_LEVEL: "info"
  EXIT_ON_ERROR: "true"
  JWT_PUBLIC_KEY: "{{ JWT_PUBLIC_KEY }}"
  SC_DOMAIN: "{{ DOMAIN }}"
  API_HOST: "{{ API_HOST }}"
  FEATURE_PROMETHEUS_METRICS_ENABLED: "true"
  SESSION_VALKEY__MODE: "{{ SESSION_VALKEY__MODE }}"
  SESSION_VALKEY__SENTINEL_NAME: "{{ SESSION_VALKEY__SENTINEL_NAME }}"
  SESSION_VALKEY__SENTINEL_SERVICE_NAME: "{{ SESSION_VALKEY__SENTINEL_SERVICE_NAME }}"
