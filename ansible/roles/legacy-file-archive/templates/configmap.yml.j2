apiVersion: v1
kind: ConfigMap
metadata:
  name: legacy-file-archive-configmap
  namespace: {{ NAMESPACE }}
  labels:
    app: legacy-file-archive
data:
  NEST_LOG_LEVEL: "info"
  EXIT_ON_ERROR: "true"
  JWT_PUBLIC_KEY: "{{ JWT_PUBLIC_KEY }}"
  SC_DOMAIN: "{{ DOMAIN }}"
  API_HOST: "{{ API_HOST }}"
  INCOMING_REQUEST_TIMEOUT_MS: "600000"
